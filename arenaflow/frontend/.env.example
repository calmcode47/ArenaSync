# ArenaFlow Frontend Environment Variables
# Copy to .env.local for development, .env.production for production builds

# Backend API base URL (include /api/v1 — no trailing slash)
VITE_API_URL=http://localhost:8000/api/v1

# Google Maps JavaScript API key (must have Maps JS, Places, Visualization, Geometry libraries enabled)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Demo credentials (for hackathon judge access — creates a staff user)
VITE_DEMO_EMAIL=demo@arenaflow.app
VITE_DEMO_PASSWORD=ArenaFlow2026!

# App metadata
VITE_APP_NAME=ArenaFlow
VITE_APP_VERSION=1.0.0
