# App
APP_ENV=development
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ═══════════════════════════════════════════════════
# DATABASE — Supabase PostgreSQL
# ═══════════════════════════════════════════════════
# Use the "Transaction Mode" pooler URL from Supabase dashboard:
# Project Settings → Database → Connection String → URI
# IMPORTANT: Replace "postgresql://" with "postgresql+asyncpg://"
# IMPORTANT: Add "?prepared_statement_cache_size=0" to the URL
#   (required for Supabase PgBouncer transaction-mode pooling with asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?prepared_statement_cache_size=0

# For Alembic migrations, use the DIRECT connection (not pooler):
# Project Settings → Database → Connection String → URI (Direct connection)
# Replace "postgresql://" with "postgresql+psycopg2://" for Alembic sync driver
DATABASE_MIGRATION_URL=postgresql+psycopg2://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Firebase
FIREBASE_CREDENTIALS_PATH=./firebase_credentials.json
FIREBASE_PROJECT_ID=your_project_id

# Google APIs (Backend)
GOOGLE_MAPS_API_KEY=your_server_side_maps_key_here
GOOGLE_TRANSLATE_API_KEY=your_translate_key

# CORS - in production, set this to your Vercel/Netlify frontend URL
ALLOWED_ORIGINS=http://localhost:5173,https://your-arenaflow-deploy.vercel.app

# ═══════════════════════════════════════════
# DEMO SEED CREDENTIALS
# Used by scripts/seed_demo.py
# ═══════════════════════════════════════════
ADMIN_EMAIL=admin@arenaflow.app
ADMIN_PASSWORD=your_admin_password_here
DEMO_STAFF_EMAIL=demo@arenaflow.app
DEMO_STAFF_PASSWORD=your_staff_password_here

# Optional: enable SQL query logging in development
DB_ECHO=false
