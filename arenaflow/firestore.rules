// firestore.rules — Minimal secure rules for ArenaFlow
// ArenaFlow primarily uses PostgreSQL via FastAPI.
// Firestore is only used for FCM token storage and real-time alert fan-out.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // FCM tokens: user can only read/write their own token
    match /fcm_tokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Alerts: readable by authenticated users, writable only by backend service account
    match /alerts/{alertId} {
      allow read: if request.auth != null;
      allow write: if false;  // Only backend (Admin SDK) can write alerts
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
